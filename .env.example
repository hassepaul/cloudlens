# ─────────────────────────────────────────────────────────────────────────────
# CloudLens — Environment Variables
# Copy to .env for local development. NEVER commit .env to version control.
# In Azure Container Apps, set these as Container App secrets / env vars.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=CloudLens
APP_VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ── API Security ─────────────────────────────────────────────────────────────
INTERNAL_API_KEY=change-me-in-production   # Used for ingest trigger + admin endpoints

# ── Azure AD (CloudLens managed identity) ────────────────────────────────────
AZURE_TENANT_ID=<cloudlens-azure-ad-tenant-id>
AZURE_CLIENT_ID=<cloudlens-managed-identity-client-id>

# ── Cosmos DB ─────────────────────────────────────────────────────────────────
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_DATABASE=cloudlens
COSMOS_CONTAINER_TENANTS=tenants
COSMOS_CONTAINER_COST_RECORDS=cost_records
COSMOS_CONTAINER_WASTE_ITEMS=waste_items
COSMOS_CONTAINER_REPORTS=reports

# ── Blob Storage ──────────────────────────────────────────────────────────────
STORAGE_ACCOUNT_NAME=<storage-account-name>
STORAGE_CONTAINER_REPORTS=reports
BLOB_SAS_EXPIRY_HOURS=1

# ── Service Bus ───────────────────────────────────────────────────────────────
SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net
SERVICE_BUS_QUEUE_INGEST=cost-ingest
SERVICE_BUS_MAX_MESSAGE_COUNT=10

# ── Key Vault ─────────────────────────────────────────────────────────────────
KEY_VAULT_NAME=<key-vault-name>

# ── Ingest ────────────────────────────────────────────────────────────────────
INGEST_LOOKBACK_DAYS=30
INGEST_MAX_RETRIES=3
INGEST_RETRY_BACKOFF_SECONDS=2.0

# ── Rate limits (req/min per tenant) ─────────────────────────────────────────
RATE_LIMIT_STARTER=60
RATE_LIMIT_GROWTH=200
RATE_LIMIT_ENTERPRISE=600
